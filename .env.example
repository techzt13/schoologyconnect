SCHOOLOGY_KEY=your_consumer_key_here
SCHOOLOGY_SECRET=your_consumer_secret_here
PORT=3000

# Optional: GitHub Copilot token used to rewrite update bodies into cleaner,
# easier-to-read summaries. If unset, the app still works — it just returns
# the raw Schoology update text unchanged.
GITHUB_TOKEN=your_github_copilot_token_here
# Optional override — defaults to a cheap model.
COPILOT_MODEL=gpt-4o-mini
