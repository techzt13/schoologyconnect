SCHOOLOGY_KEY=your_consumer_key_here
SCHOOLOGY_SECRET=your_consumer_secret_here
PORT=3000

# Optional: GitHub Copilot token used to rewrite update bodies into cleaner,
# easier-to-read summaries. If unset, the app still works — it just returns
# the raw Schoology update text unchanged.
GITHUB_TOKEN=your_github_copilot_token_here
# Optional override — defaults to a cheap model.
COPILOT_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Email notifications (optional)
#
# When configured, the server will send an email to everyone in NOTIFY_EMAILS
# every time a new Schoology update is seen (i.e. an update whose id has not
# been observed by this server process before). The first call to /api/updates
# primes the "seen" cache without sending any emails, so you don't get blasted
# by the entire backlog on startup.
#
# SMTP_USER must be a Gmail address and SMTP_PASS must be a Google *app
# password* (not your normal account password). See README.md for setup.
# ---------------------------------------------------------------------------
SMTP_USER=zackt.atp@gmail.com
SMTP_PASS=your_gmail_app_password_here
# Comma-separated list of recipient addresses. Defaults shown below.
NOTIFY_EMAILS=zackt.atp@gmail.com,klpgiraffe@gmail.com
# Optional "From" header. Defaults to SMTP_USER.
NOTIFY_FROM=zackt.atp@gmail.com
